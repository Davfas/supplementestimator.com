---
const items = [
  'Xactimate Certified',
  'Former Licensed Adjuster',
  'White Label Service',
  'Roofing, GC & Restoration',
];
---

<section class="px-5 md:px-8 py-12 border-t border-b border-accent/15">
  <div class="max-w-page mx-auto flex justify-center gap-6 md:gap-12 flex-wrap">
    {items.map((item) => (
      <div class="flex items-center gap-3 text-slate-400 text-[0.9rem] font-medium">
        <div class="w-9 h-9 bg-surface rounded-lg flex items-center justify-center text-accent-teal text-base">
          ✓
        </div>
        {item}
      </div>
    ))}
  </div>
</section>
