---
---

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css" />

<section id="contact" class="relative py-32 px-5 md:px-8 overflow-hidden">

  <!-- Parallax background -->
  <div
    class="absolute inset-0"
    style="background-image: url('/hail-storm-cta.jpg'); background-attachment: fixed; background-size: cover; background-position: center;"
  ></div>

  <div class="relative z-10 max-w-[860px] mx-auto text-center">

    <div class="text-xs font-semibold tracking-[0.1em] uppercase text-accent-teal mb-6">Get Started</div>

    <h2 class="font-heading text-[2rem] md:text-[3rem] font-extrabold tracking-[-0.03em] text-white mb-6 leading-[1.1]">
      Send us a claim.<br/>See what you've been missing.
    </h2>

    <p class="text-slate-800 text-[1.1rem] mb-12 leading-[1.7] max-w-[600px] mx-auto font-medium">
      No contracts, no minimums. Send us a scope of loss and we'll show you exactly what the carrier left off. If you like what you see, we'll talk about working together.
    </p>

    <!-- CTA buttons -->
    <div class="flex flex-wrap gap-4 justify-center mb-14">
      <a
        href="tel:6128007765"
        class="inline-flex items-center gap-2 bg-accent hover:bg-blue-600 text-white px-8 py-4 rounded-md font-semibold text-[0.95rem] transition-[background,transform] hover:-translate-y-px no-underline"
      >
        <i class="ti ti-phone text-[1.1rem]" aria-hidden="true"></i>
        Call 612-800-7765
      </a>
      <a
        href="https://calendar.proton.me/bookings#bj7IFdAKXGl4shtSU8nfmLD3wA7IHSrW5r_ZmsUGv28="
        class="inline-flex items-center gap-2 bg-accent-teal hover:bg-teal-500 text-white px-8 py-4 rounded-md font-semibold text-[0.95rem] transition-[background,transform] hover:-translate-y-px no-underline"
      >
        <i class="ti ti-calendar text-[1.1rem]" aria-hidden="true"></i>
        Schedule a Call
      </a>
      <a
        href="mailto:info@supplementestimator.com"
        class="inline-flex items-center gap-2 bg-slate-700 hover:bg-slate-600 text-white px-8 py-4 rounded-md font-semibold text-[0.95rem] transition-[background,transform] hover:-translate-y-px no-underline"
      >
        <i class="ti ti-mail text-[1.1rem]" aria-hidden="true"></i>
        Email Us
      </a>
    </div>

    <!-- Trust chips -->
    <div class="flex flex-wrap gap-6 justify-center mb-12">
      <div class="flex items-center gap-2 text-slate-400 text-sm">
        <i class="ti ti-circle-check text-accent-teal" aria-hidden="true"></i>
        No contracts
      </div>
      <div class="flex items-center gap-2 text-slate-400 text-sm">
        <i class="ti ti-circle-check text-accent-teal" aria-hidden="true"></i>
        No minimums
      </div>
      <div class="flex items-center gap-2 text-slate-400 text-sm">
        <i class="ti ti-circle-check text-accent-teal" aria-hidden="true"></i>
        First claim reviewed free
      </div>
      <div class="flex items-center gap-2 text-slate-400 text-sm">
        <i class="ti ti-circle-check text-accent-teal" aria-hidden="true"></i>
        Nationwide coverage
      </div>
    </div>

    <!-- Contact info -->
    <div class="border-t border-accent/15 pt-8 flex flex-wrap gap-8 justify-center text-slate-500 text-[0.9rem]">
      <span class="text-slate-400 font-medium">Dave Faso</span>
      <a href="tel:6128007765" class="hover:text-accent transition-colors no-underline">612-800-7765</a>
      <a href="mailto:info@supplementestimator.com" class="hover:text-accent transition-colors no-underline">info@supplementestimator.com</a>
    </div>

  </div>
</section>
