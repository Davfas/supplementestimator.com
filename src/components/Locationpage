---
import Layout from '../layouts/Layout.astro';
import CTA from './CTA.astro';

interface Props {
  state: string;
  stateAbbr: string;
  blurb: string;
}

const { state, stateAbbr, blurb } = Astro.props;

const title = `Insurance Supplement Estimator in ${state} | Precision Estimating`;
const description = `Precision Estimating serves roofing contractors, GCs, and restoration companies in ${state}. Xactimate estimates, supplement writing, and carrier negotiations — nationwide remote service.`;
const canonical = `https://supplementestimator.com/locations/${state.toLowerCase().replace(/\s+/g, '-')}`;

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": `Insurance Supplement Estimating in ${state}`,
  "provider": {
    "@type": "ProfessionalService",
    "name": "Precision Estimating and Supplements",
    "url": "https://supplementestimator.com"
  },
  "description": description,
  "url": canonical,
  "areaServed": {
    "@type": "State",
    "name": state,
    "addressCountry": "US"
  },
  "serviceType": [
    "Xactimate Estimate Writing",
    "Supplement Writing",
    "Insurance Carrier Negotiations"
  ]
};

const services = [
  {
    icon: "ti-file-description",
    title: "Xactimate Estimate Writing",
    body: `We write carrier-ready Xactimate estimates for ${state} contractors. Accurate, fully documented, and priced correctly from the start.`,
    href: "/services/xactimate-estimate-writing"
  },
  {
    icon: "ti-file-plus",
    title: "Supplement Writing",
    body: `Carriers in ${state} routinely underpay. We identify every missed line item and recover the money your ${state} claims deserve.`,
    href: "/services/supplement-writing"
  },
  {
    icon: "ti-gavel",
    title: "Carrier Negotiations",
    body: `We negotiate directly with carriers on behalf of ${state} contractors — backed by a former licensed adjuster who knows their playbook.`,
    href: "/services/carrier-negotiations"
  },
  {
    icon: "ti-school",
    title: "Consulting & Training",
    body: `Want to improve your in-house claims process in ${state}? We offer Xactimate training and consulting for contractors at every experience level.`,
    href: "/services/consulting-training"
  }
];
---

<Layout title={title} description={description} canonical={canonical} schema={schema}>

  <!-- Hero -->
  <section class="px-5 md:px-8 pt-32 pb-20 bg-secondary relative overflow-hidden">
    <div class="hero-glow absolute inset-0 pointer-events-none"></div>
    <div class="max-w-page mx-auto text-center relative z-10">
      <div class="inline-flex items-center gap-2 bg-surface border border-accent/20 rounded-full px-4 py-1.5 text-accent text-sm font-medium mb-6">
        <i class="ti ti-map-pin"></i> Serving {state} Contractors
      </div>
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-white mb-4 leading-tight">
        Insurance Supplement Estimating<br class="hidden md:block" /> in {state}
      </h1>
      <p class="text-slate-300 text-lg md:text-xl max-w-2xl mx-auto mb-8">
        {blurb}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:+16057602228" class="inline-flex items-center justify-center gap-2 bg-accent hover:bg-accent/90 text-white font-semibold px-6 py-3 rounded-xl transition-colors">
          <i class="ti ti-phone"></i> Call Now
        </a>
        <a href="mailto:dave@supplementestimator.com" class="inline-flex items-center justify-center gap-2 bg-surface border border-accent/20 hover:border-accent/50 text-white font-semibold px-6 py-3 rounded-xl transition-colors">
          <i class="ti ti-mail"></i> Email Us
        </a>
      </div>
    </div>
  </section>

  <!-- Trust bar -->
  <section class="px-5 md:px-8 py-8 border-t border-b border-accent/15">
    <div class="max-w-page mx-auto flex flex-wrap justify-center gap-6 md:gap-12">
      {[
        { icon: 'ti-certificate', label: 'Xactimate Certified' },
        { icon: 'ti-shield-check', label: 'Former Licensed Adjuster' },
        { icon: 'ti-eye-off', label: 'White Label Service' },
        { icon: 'ti-map-pin', label: `Serving ${stateAbbr} Contractors` },
      ].map((item) => (
        <div class="flex items-center gap-3 text-slate-300 text-[0.9rem] font-medium">
          <div class="w-9 h-9 bg-surface border border-accent/20 rounded-lg flex items-center justify-center">
            <i class={`ti ${item.icon}`} style="font-size: 1.1rem; color: #14B8A6;"></i>
          </div>
          {item.label}
        </div>
      ))}
    </div>
  </section>

  <!-- Services -->
  <section class="px-5 md:px-8 py-20 bg-primary">
    <div class="max-w-page mx-auto">
      <h2 class="font-heading text-3xl font-bold text-white text-center mb-4">
        Services for {state} Contractors
      </h2>
      <p class="text-slate-400 text-center max-w-2xl mx-auto mb-12">
        We work 100% remotely — no matter where you are in {state}, we can handle your estimates, supplements, and carrier negotiations.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {services.map((s) => (
          <a href={s.href} class="bg-surface border border-accent/15 hover:border-accent/40 rounded-2xl p-6 transition-colors group">
            <div class="w-10 h-10 bg-primary border border-accent/20 rounded-lg flex items-center justify-center mb-4">
              <i class={`ti ${s.icon}`} style="font-size: 1.2rem; color: #14B8A6;"></i>
            </div>
            <h3 class="font-heading text-lg font-semibold text-white mb-2 group-hover:text-accent transition-colors">{s.title}</h3>
            <p class="text-slate-400 text-sm leading-relaxed">{s.body}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why us -->
  <section class="px-5 md:px-8 py-20 bg-secondary">
    <div class="max-w-page mx-auto max-w-3xl text-center">
      <h2 class="font-heading text-3xl font-bold text-white mb-6">
        Why {state} Contractors Choose Precision
      </h2>
      <p class="text-slate-300 text-lg leading-relaxed mb-8">
        Dave Faso is a former licensed insurance adjuster and Xactimate-certified estimator with 7,000+ claims under his belt. He spent years on the carrier side — which means he knows exactly how to document claims that get approved and supplements that get paid.
      </p>
      <p class="text-slate-300 text-lg leading-relaxed mb-8">
        We work 100% remotely and serve contractors in all 50 states. Whether you're a roofing contractor, general contractor, or restoration company in {state}, we can turn around estimates and supplements fast so you get paid without the wait.
      </p>
      <a href="tel:+16057602228" class="inline-flex items-center gap-2 bg-accent hover:bg-accent/90 text-white font-semibold px-8 py-3 rounded-xl transition-colors text-lg">
        <i class="ti ti-phone"></i> Talk to Dave Today
      </a>
    </div>
  </section>

  <CTA />
</Layout>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css" />
