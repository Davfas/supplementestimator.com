    svgId: 'svg-estimate',
  },
  {
    icon: 'ti-search',
    accent: '#14B8A6',
    title: 'Supplement Writing',
    body: "We tear apart the carrier's scope line by line. Missing materials, underpaid labor, code upgrades, overlooked damage. If it belongs on the claim, we find it.",
    svgId: 'svg-supplement',
  },
  {
    icon: 'ti-messages',
    accent: '#3B82F6',
    title: 'Carrier Negotiations',
    body: "We go back and forth with the adjuster so you don't have to. Documentation, follow-ups, pushback. We know what gets approved.",
    svgId: 'svg-negotiations',
  },
  {
    icon: 'ti-receipt',
    accent: '#14B8A6',
    title: 'Final Invoice Submission',
    body: 'After the work is done, we prepare and submit the final invoice, handle documentation requests, and follow up until the payment clears.',
    svgId: 'svg-invoice',
  },
  {
    icon: 'ti-school',
    accent: '#3B82F6',
    title: 'Consulting & Training',
    body: 'Want your team to handle supplements in-house? We train your people on Xactimate, supplement strategy, and what to look for on every claim.',
    svgId: 'svg-training',
  },
  {
    icon: 'ti-shield-check',
    accent: '#14B8A6',
    title: 'Fully White Labeled',
    body: "We work inside your CRM, from your email, under your name. To the carrier, we're your employee. Your brand stays front and center.",
    svgId: 'svg-whitelabel',
  },
];

