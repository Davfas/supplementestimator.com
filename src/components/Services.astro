---

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css" />

<section id="services" class="px-5 md:px-8 py-24 max-w-page mx-auto">
  <div class="text-xs font-semibold tracking-[0.1em] uppercase text-accent-teal mb-4">What We Do</div>
  <h2 class="font-heading text-[2rem] md:text-[2.5rem] font-bold tracking-[-0.02em] text-white mb-4 max-w-[600px]">
    Every stage of the claim, handled.
  </h2>
  <p class="text-slate-400 text-[1.05rem] max-w-[550px] mb-14 leading-[1.7]">
    From the initial estimate to the final invoice, we handle the paperwork so you can stay on the job site.
  </p>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    {services.map((s) => (
      <article class="bg-secondary border border-accent/15 rounded-xl overflow-hidden transition-[border-color,transform] duration-300 hover:border-accent hover:-translate-y-0.5">
        <div class="w-full overflow-hidden" set:html={s.svg} />
        <div class="h-1 w-full" style={`background: ${s.accent};`}></div>
        <div class="p-8">
          <div
            class="w-12 h-12 rounded-[10px] flex items-center justify-center mb-6"
            style={`background: ${s.accent}18; border: 1px solid ${s.accent}30;`}
          >
            <i class={`ti ${s.icon}`} style={`font-size: 1.4rem; color: ${s.accent};`} aria-hidden="true"></i>
          </div>
          <h3 class="font-heading text-[1.25rem] font-bold text-white mb-3">{s.title}</h3>
          <p class="text-slate-400 text-[0.95rem] leading-[1.65]">{s.body}</p>
        </div>
      </article>
    ))}
  </div>
</section>
