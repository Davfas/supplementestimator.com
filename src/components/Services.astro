      <text x="220" y="56" text-anchor="middle" fill="#475569" font-size="6" font-family="sans-serif">Writing estimates</text>
      <text x="220" y="65" text-anchor="middle" fill="#475569" font-size="6" font-family="sans-serif">Building supplements</text>
      <rect x="170" y="75" width="100" height="25" rx="4" fill="#071a10"/>
      <text x="220" y="86" text-anchor="middle" fill="#475569" font-size="6" font-family="sans-serif">Carrier communication</text>
      <text x="220" y="95" text-anchor="middle" fill="#475569" font-size="6" font-family="sans-serif">Under your email</text>
