---
const steps = [
  {
    n: '01',
    icon: 'ti-video',
    title: 'Onboarding Call',
    body: 'Quick Zoom call. We learn your workflow, your CRM, your preferences. We set up access and hit the ground running.',
  },
  {
    n: '02',
    icon: 'ti-file-upload',
    title: 'Send Your Files',
    body: 'Email them, assign them in your CRM, or we pull them ourselves. Scope of loss, photos, measurements, notes.',
  },
  {
    n: '03',
    icon: 'ti-tool',
    title: 'We Build It',
    body: 'Detailed Xactimate estimate or supplement with every missing line item, code upgrade, and pricing correction documented.',
  },
  {
    n: '04',
    icon: 'ti-messages',
    title: 'Carrier Negotiation',
    body: "We submit to the carrier, handle their questions, push back on denials, and follow up until it's resolved.",
  },
  {
    n: '05',
    icon: 'ti-cash',
    title: 'You Get Paid',
    body: 'Supplement approved, final invoice submitted, payment released. We hand you the updated paperwork and you move on.',
  },
];
---

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css" />

<section
  id="process"
  class="relative px-5 md:px-8 py-24 border-t border-b border-accent/15 overflow-hidden"
  style="background-color: #0C1926;"
>
  <!-- Parallax background -->
  <div
    class="absolute inset-0 bg-center bg-cover"
    style="background-image: url('/how-it-works-bg.png'); background-attachment: fixed; background-size: cover; background-position: center; opacity: 0.9;"
  ></div>

  <!-- Dark overlay for readability -->
  <div class="absolute inset-0" style="background: linear-gradient(to bottom, #0C192666, #162A3E88);"></div>

  <div class="max-w-page mx-auto relative z-10">
    <div class="text-xs font-semibold tracking-[0.1em] uppercase text-accent-teal mb-4">How It Works</div>
    <h2 class="font-heading text-[2rem] md:text-[2.5rem] font-bold tracking-[-0.02em] text-white mb-4 max-w-[600px]">
      Five steps. You stay on the roof.
    </h2>
    <p class="text-slate-300 text-[1.05rem] max-w-[550px] mb-14 leading-[1.7]">
      We built our process to take work off your plate, not add to it.
    </p>

    <ol class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-2 md:gap-4 list-none p-0 m-0">
      {steps.map((s, i) => (
        <li class="relative flex flex-row lg:flex-col items-start lg:items-center gap-4 lg:gap-0 text-left lg:text-center py-4 lg:py-0">
          {i < steps.length - 1 && (
            <div class="hidden lg:block absolute top-[28px] left-[calc(50%+28px)] right-[calc(-50%+28px)] h-px bg-accent/30 z-0"></div>
          )}
          <div class="relative z-10 w-14 h-14 rounded-full border-2 border-accent/50 flex items-center justify-center mb-0 lg:mb-5 shrink-0 lg:shrink" style="background: rgba(12,25,38,0.85);">
            <i class={`ti ${s.icon}`} style="font-size: 1.3rem; color: #3B82F6;" aria-hidden="true"></i>
          </div>
          <div class="rounded-xl p-4 lg:p-5" style="background: rgba(12,25,38,0.75); backdrop-filter: blur(4px);">
            <div class="font-heading text-[0.7rem] font-bold text-accent-teal uppercase tracking-[0.12em] mb-1">{s.n}</div>
            <h4 class="font-heading text-base font-extrabold text-white mb-2">{s.title}</h4>
            <p class="text-slate-300 text-[0.85rem] leading-[1.6]">{s.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
