---
const links = [
  { href: '#services', label: 'Services' },
  { href: '#process', label: 'Process' },
  { href: '#about', label: 'About' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 px-5 md:px-8 py-5 flex items-center justify-between bg-primary/90 backdrop-blur-md border-b border-accent/15">
  <a href="/" class="flex flex-col no-underline">
    <span class="font-heading font-bold text-[1.15rem] text-white tracking-tight leading-tight">Precision Estimating</span>
    <span class="text-[0.7rem] text-accent font-medium tracking-[0.08em] uppercase">&amp; Supplements</span>
  </a>

  <ul class="hidden md:flex gap-8 items-center list-none m-0 p-0">
    {links.map((l) => (
      <li>
        <a href={l.href} class="text-slate-400 hover:text-white text-sm font-medium transition-colors no-underline">
          {l.label}
        </a>
      </li>
    ))}
    <li>
      <a
        href="#contact"
        class="bg-accent hover:bg-blue-600 text-white px-6 py-2.5 rounded-md font-semibold text-sm transition-colors no-underline"
      >
        Get Started
      </a>
    </li>
  </ul>

  <button
    id="mobile-menu-btn"
    type="button"
    class="md:hidden bg-transparent border-0 text-white text-2xl cursor-pointer p-1 leading-none"
    aria-label="Toggle navigation menu"
    aria-expanded="false"
    aria-controls="mobile-menu"
  >
    <span id="mobile-menu-icon" aria-hidden="true">☰</span>
  </button>
</nav>

<!-- Mobile menu panel -->
<div
  id="mobile-menu"
  class="hidden md:hidden fixed top-[68px] left-0 right-0 z-40 bg-primary/95 backdrop-blur-md border-b border-accent/15"
>
  <ul class="flex flex-col gap-1 p-6 m-0 list-none">
    {links.map((l) => (
      <li>
        <a href={l.href} class="block py-3 text-slate-400 hover:text-white text-base font-medium transition-colors no-underline">
          {l.label}
        </a>
      </li>
    ))}
    <li>
      <a
        href="#contact"
        class="block mt-2 bg-accent hover:bg-blue-600 text-white px-6 py-3 rounded-md font-semibold text-center transition-colors no-underline"
      >
        Get Started
      </a>
    </li>
  </ul>
</div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const icon = document.getElementById('mobile-menu-icon');

  function setOpen(open: boolean) {
    if (!btn || !menu || !icon) return;
    menu.classList.toggle('hidden', !open);
    btn.setAttribute('aria-expanded', String(open));
    icon.textContent = open ? '✕' : '☰';
  }

  btn?.addEventListener('click', () => {
    const isHidden = menu?.classList.contains('hidden') ?? true;
    setOpen(isHidden);
  });

  // Close menu when any link inside it is tapped.
  menu?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => setOpen(false));
  });
</script>
