---
const services = [
  { href: '/services/xactimate-estimate-writing', label: 'Xactimate Estimate Writing' },
  { href: '/services/supplement-writing', label: 'Supplement Writing' },
  { href: '/services/carrier-negotiations', label: 'Carrier Negotiations' },
  { href: '/services/final-invoice-submission', label: 'Final Invoice Submission' },
  { href: '/services/consulting-training', label: 'Consulting & Training' },
  { href: '/services/white-label-services', label: 'Fully White Labeled' },
];

const locations = [ 
  { href: '/locations/minnesota', label: 'Minnesota' },
  { href: '/locations/colorado', label: 'Colorado' },
  { href: '/locations/south-dakota', label: 'South Dakota' },
  { href: '/locations/wisconsin', label: 'Wisconsin' },
  { href: '/locations/wyoming', label: 'Wyoming' },
  { href: '/locations/florida', label: 'Florida' },
  { href: '/locations/arizona', label: 'Arizona' },
  { href: '/locations/nebraska', label: 'Nebraska' },
  { href: '/locations/iowa', label: 'Iowa' },
  { href: '/locations/missouri', label: 'Missouri' },
  { href: '/locations/alaska', label: 'Alaska' },
  { href: '/locations/connecticut', label: 'Connecticut' },
  { href: '/locations/kentucky', label: 'Kentucky' },
  { href: '/locations/rhode-island', label: 'Rhode Island' },
  { href: '/locations/utah', label: 'Utah' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 px-5 md:px-8 py-4 flex items-center justify-between bg-primary/90 backdrop-blur-md border-b border-accent/15">

  <a href="/" class="flex items-center gap-3 no-underline">
    <img src="/precision-icon.png" alt="Precision Estimating and Supplements" class="h-16 w-auto" />
  </a>

  <ul class="hidden md:flex gap-8 items-center list-none m-0 p-0 absolute left-1/2 -translate-x-1/2">
    <li>
      <a href="/" class="text-slate-400 hover:text-white text-sm font-medium transition-colors no-underline">Home</a>
    </li>
    <li class="relative group">
      <a href="/services" class="text-slate-400 hover:text-white text-sm font-medium transition-colors no-underline flex items-center gap-1">
        Services <span class="text-xs">▾</span>
      </a>
      <div class="absolute top-full left-0 mt-2 w-64 bg-primary border border-accent/20 rounded-xl shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
        <ul class="list-none m-0 p-2">
          {services.map((s) => (
            <li>
              <a href={s.href} class="block px-4 py-2.5 text-slate-400 hover:text-white hover:bg-accent/10 rounded-lg text-sm font-medium transition-colors no-underline">
                {s.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </li>
    <li class="relative group">
      <a href="/locations" class="text-slate-400 hover:text-white text-sm font-medium transition-colors no-underline flex items-center gap-1">
        Locations <span class="text-xs">▾</span>
      </a>
      <div class="absolute top-full left-0 mt-2 w-48 bg-primary border border-accent/20 rounded-xl shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
        <ul class="list-none m-0 p-2">
          {locations.map((l) => (
            <li>
              <a href={l.href} class="block px-4 py-2.5 text-slate-400 hover:text-white hover:bg-accent/10 rounded-lg text-sm font-medium transition-colors no-underline">
                {l.label}
              </a>
            </li>
          ))}
          <li>
            <a href="/locations" class="block px-4 py-2.5 text-accent-teal hover:text-white hover:bg-accent/10 rounded-lg text-sm font-semibold transition-colors no-underline border-t border-accent/10 mt-1 pt-3">
              View All States →
            </a>
          </li>
        </ul>
      </div>
    </li>
    <li>
      <a href="#process" class="text-slate-400 hover:text-white text-sm font-medium transition-colors no-underline">Process</a>
    </li>
    <li>
      <a href="#about" class="text-slate-400 hover:text-white text-sm font-medium transition-colors no-underline">About</a>
    </li>
    <li>
      <a href="/blog" class="text-slate-400 hover:text-white text-sm font-medium transition-colors no-underline">Blog</a>
    </li>
  </ul>

  <div class="hidden md:flex items-center gap-3">
  <a href="tel:6128007765" class="text-slate-400 hover:text-white text-sm font-medium transition-colors no-underline flex items-center gap-1.5">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.6 19.79 19.79 0 0 1 1.6 4.92 2 2 0 0 1 3.6 2.73h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.33a16 16 0 0 0 5.76 5.76l1.69-1.69a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
    612-800-7765
  </a>
  <a href="#contact" class="bg-accent hover:bg-blue-600 text-white px-6 py-2.5 rounded-md font-semibold text-sm transition-colors no-underline">
    Get Started
  </a>
</div>

  <button
    id="mobile-menu-btn"
    type="button"
    class="md:hidden bg-transparent border-0 text-white text-2xl cursor-pointer p-1 leading-none"
    aria-label="Toggle navigation menu"
    aria-expanded="false"
    aria-controls="mobile-menu"
  >
    <span id="mobile-menu-icon" aria-hidden="true">☰</span>
  </button>
</nav>

<div
  id="mobile-menu"
  class="hidden md:hidden fixed top-[68px] left-0 right-0 z-40 bg-primary/95 backdrop-blur-md border-b border-accent/15"
>
  <ul class="flex flex-col gap-1 p-6 m-0 list-none">
    <li>
      <a href="/" class="block py-3 text-slate-400 hover:text-white text-base font-medium transition-colors no-underline">Home</a>
    </li>
    <li class="py-1">
      <div class="text-xs font-semibold uppercase tracking-widest text-accent-teal mb-2">Services</div>
      <ul class="list-none m-0 p-0 flex flex-col gap-1">
        {services.map((s) => (
          <li>
            <a href={s.href} class="block py-2 pl-3 text-slate-400 hover:text-white text-sm font-medium transition-colors no-underline border-l border-accent/20">
              {s.label}
            </a>
          </li>
        ))}
      </ul>
    </li>
    <li class="py-1">
      <div class="text-xs font-semibold uppercase tracking-widest text-accent-teal mb-2">Locations</div>
      <ul class="list-none m-0 p-0 flex flex-col gap-1">
        {locations.map((l) => (
          <li>
            <a href={l.href} class="block py-2 pl-3 text-slate-400 hover:text-white text-sm font-medium transition-colors no-underline border-l border-accent/20">
              {l.label}
            </a>
          </li>
        ))}
        <li>
          <a href="/locations" class="block py-2 pl-3 text-accent-teal text-sm font-semibold transition-colors no-underline border-l border-accent-teal/40">
            View All States →
          </a>
        </li>
      </ul>
    </li>
    <li>
      <a href="#process" class="block py-3 text-slate-400 hover:text-white text-base font-medium transition-colors no-underline">Process</a>
    </li>
    <li>
      <a href="#about" class="block py-3 text-slate-400 hover:text-white text-base font-medium transition-colors no-underline">About</a>
    </li>
    <li>
      <a href="/blog" class="block py-3 text-slate-400 hover:text-white text-base font-medium transition-colors no-underline">Blog</a>
    </li>
    <li>
      <a href="tel:6128007765" class="flex items-center justify-center gap-2 mt-2 border border-accent/40 text-white px-6 py-3 rounded-md font-semibold text-center transition-colors no-underline">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.6 19.79 19.79 0 0 1 1.6 4.92 2 2 0 0 1 3.6 2.73h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.33a16 16 0 0 0 5.76 5.76l1.69-1.69a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        612-800-7765
      </a>
    </li>
    <li>
      <a href="#contact" class="block mt-2 bg-accent hover:bg-blue-600 text-white px-6 py-3 rounded-md font-semibold text-center transition-colors no-underline">
        Get Started
      </a>
    </li>
  </ul>
</div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const icon = document.getElementById('mobile-menu-icon');

  function setOpen(open: boolean) {
    if (!btn || !menu || !icon) return;
    menu.classList.toggle('hidden', !open);
    btn.setAttribute('aria-expanded', String(open));
    icon.textContent = open ? '✕' : '☰';
  }

  btn?.addEventListener('click', () => {
    const isHidden = menu?.classList.contains('hidden') ?? true;
    setOpen(isHidden);
  });

  menu?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => setOpen(false));
  });
</script>
