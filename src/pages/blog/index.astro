---
import Layout from '../../layouts/Layout.astro';
import CTA from '../../components/CTA.astro';

const posts = [
  {
    href: "/blog/claim-documentation-checklist",
    slug: "claim-documentation-checklist",
    title: "The Complete Claim Documentation Checklist for Roofing Contractors",
    excerpt: "From signing the contract to submitting for supplementing — everything your field team needs to document so your claims team can get you paid.",
    date: "June 14, 2026",
    readTime: "8 min read",
    image: "/firefly-xactimate-hands.png",
    category: "Claims Management"
  },
  {
    href: "/blog/photos-required-for-supplements",
    slug: "photos-required-for-supplements",
    title: "Every Photo You Need to Supplement a Roofing Claim (And Why)",
    excerpt: "Missing photos are the number one reason supplements get denied. Here's the complete photo checklist for roof inspections, reinspections, exterior damage, and build documentation.",
    date: "June 14, 2026",
    readTime: "6 min read",
    image: "/firefly-hail-damage.png",
    category: "Supplement Writing"
  }
];

const schema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Precision Estimating and Supplements Blog",
  "url": "https://supplementestimator.com/blog",
  "description": "Insurance supplement and estimating tips, checklists, and guides for roofing contractors, GCs, and restoration companies."
};
---

<Layout
  title="Blog | Precision Estimating and Supplements"
  description="Insurance supplement and estimating tips, checklists, and guides for roofing contractors, GCs, and restoration companies."
  canonical="https://supplementestimator.com/blog"
  schema={schema}
>

  <!-- Hero -->
  <section class="px-5 md:px-8 pt-32 pb-20 bg-secondary relative overflow-hidden">
    <div class="hero-glow absolute inset-0 pointer-events-none"></div>
    <div class="max-w-page mx-auto relative z-10">
      <div class="text-xs font-semibold tracking-[0.1em] uppercase text-accent-teal mb-4">Resources</div>
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-white mb-4 leading-tight">
        The Supplement & Estimating Blog
      </h1>
      <p class="text-slate-300 text-lg max-w-2xl">
        Practical guides, checklists, and field-tested advice for roofing contractors who want to get paid right on every claim.
      </p>
    </div>
  </section>

  <!-- Posts -->
  <section class="px-5 md:px-8 py-20 bg-primary">
    <div class="max-w-page mx-auto grid grid-cols-1 md:grid-cols-2 gap-8">
      {posts.map((p) => (
        
          <a href={p.href}
          class="bg-secondary border border-accent/15 rounded-xl overflow-hidden transition-[border-color,transform] duration-300 hover:border-accent hover:-translate-y-0.5 group"
        >
          <div class="w-full overflow-hidden" style="height: 220px;">
            <img
              src={p.image}
              alt={p.title}
              class="w-full h-full object-cover object-center"
            />
          </div>
          <div class="h-1 w-full bg-accent"></div>
          <div class="p-8">
            <div class="flex items-center gap-3 mb-4">
              <span class="text-xs font-semibold uppercase tracking-widest text-accent-teal">{p.category}</span>
              <span class="text-slate-600">·</span>
              <span class="text-xs text-slate-500">{p.readTime}</span>
            </div>
            <h2 class="font-heading text-[1.2rem] font-bold text-white mb-3 group-hover:text-accent-teal transition-colors leading-snug">
              {p.title}
            </h2>
            <p class="text-slate-400 text-[0.9rem] leading-relaxed mb-4">{p.excerpt}</p>
            <div class="text-accent-teal text-sm font-semibold flex items-center gap-1 group-hover:gap-2 transition-all">
              Read more <i class="ti ti-arrow-right"></i>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <CTA />
</Layout>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css" />
