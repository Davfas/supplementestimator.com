---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import Services from '../components/Services.astro';
import Process from '../components/Process.astro';
import WhiteLabel from '../components/WhiteLabel.astro';
import About from '../components/About.astro';
import CTA from '../components/CTA.astro';
---

<Layout>
  <Hero />
  <TrustBar />
  <Services />
  <Process />
  <WhiteLabel />
  <About />
  <CTA />
  <div class="px-5 md:px-8 py-6 border-t border-accent/10 max-w-page mx-auto">
    <p class="text-slate-500 text-xs leading-relaxed">
      <span class="font-semibold text-slate-400">PA DISCLOSURE:</span> Precision Estimating and Supplements IS NOT a Public Adjusting firm. At no time will we contact the insured unless for collection of a contractor's invoice. We will not discuss any portion of a claim with the insured, and we do not review or interpret policy, nor will we help or represent the insured in the collection of their claim whatsoever.
    </p>
  </div>
</Layout>
