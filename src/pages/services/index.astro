---
import Layout from '../../layouts/Layout.astro';
import CTA from '../../components/CTA.astro';

const services = [
  {
    slug: "xactimate-estimate-writing",
    image: "/firefly-xactimate-hands.png",
    accent: "#3B82F6",
    title: "Xactimate Estimate Writing",
    description: "Carrier-ready Xactimate estimates written by a certified professional and former licensed adjuster. Accurate scope, correct pricing, fast turnaround."
  },
  {
    slug: "supplement-writing",
    image: "/firefly-dual-monitor.png",
    accent: "#14B8A6",
    title: "Supplement Writing",
    description: "We audit carrier estimates, identify every missed or underpaid line item, and write complete supplements that recover money you're already owed."
  },
  {
    slug: "carrier-negotiations",
    image: "/firefly-claim-approved.png",
    accent: "#3B82F6",
    title: "Carrier Negotiations",
    description: "We negotiate directly with insurance carriers on your behalf — backed by a former adjuster who knows exactly how to document and argue a claim."
  },
  {
    slug: "consulting-training",
    image: "/firefly-training.png",
    accent: "#14B8A6",
    title: "Consulting & Training",
    description: "Improve your in-house claims process with Xactimate training and expert consulting from someone who has been on both sides of the table."
  }
];

const schema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Precision Estimating and Supplements",
  "url": "https://supplementestimator.com/services",
  "description": "Xactimate estimate writing, supplement writing, carrier negotiations, and insurance claims consulting for roofing contractors, GCs, and restoration companies.",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Insurance Estimating Services",
    "itemListElement": services.map((s, i) => ({
      "@type": "Offer",
      "position": i + 1,
      "itemOffered": {
        "@type": "Service",
        "name": s.title,
        "description": s.description,
        "url": `https://supplementestimator.com/services/${s.slug}`
      }
    }))
  }
};
---

<Layout
  title="Services | Precision Estimating and Supplements"
  description="Xactimate estimate writing, supplement writing, carrier negotiations, and consulting for roofing contractors, GCs, and restoration companies. Nationwide remote service."
  canonical="https://supplementestimator.com/services"
  schema={schema}
>

  <!-- Hero -->
  <section class="px-5 md:px-8 pt-32 pb-20 bg-secondary relative overflow-hidden">
    <div class="hero-glow absolute inset-0 pointer-events-none"></div>
    <div class="max-w-page mx-auto text-center relative z-10">
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-white mb-4 leading-tight">
        Everything You Need to Get Paid Right
      </h1>
      <p class="text-slate-300 text-lg md:text-xl max-w-2xl mx-auto">
        From writing the initial estimate to negotiating the final check — we handle the entire claims documentation process for roofing contractors, GCs, and restoration companies nationwide.
      </p>
    </div>
  </section>

  <!-- Service Cards -->
  <section class="px-5 md:px-8 py-20 bg-primary">
    <div class="max-w-page mx-auto grid grid-cols-1 md:grid-cols-2 gap-8">
      {services.map((s) => (
        
          href={`/services/${s.slug}`}
          class="bg-secondary border border-accent/15 rounded-xl overflow-hidden transition-[border-color,transform] duration-300 hover:border-accent hover:-translate-y-0.5 group"
        >
          <div class="w-full overflow-hidden" style="height: 260px;">
            <img
              src={s.image}
              alt={s.title}
              class="w-full h-full object-cover object-center"
            />
          </div>
          <div class="h-1 w-full bg-accent"></div>
          <div class="p-8">
            <h2 class="font-heading text-[1.25rem] font-bold text-white mb-3 group-hover:text-accent-teal transition-colors">
              {s.title}
            </h2>
            <p class="text-slate-400 text-[0.95rem] leading-[1.65] mb-4">{s.description}</p>
            <span class="text-accent-teal text-sm font-semibold inline-flex items-center gap-1 group-hover:gap-2 transition-all">
              Learn more <i class="ti ti-arrow-right"></i>
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <CTA />
</Layout>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css" />
