---
import Layout from '../../layouts/Layout.astro';
import CTA from '../../components/CTA.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Precision Estimating and Supplements",
  "url": "https://supplementestimator.com/services",
  "description": "Xactimate estimate writing, supplement writing, carrier negotiations, and consulting for contractors nationwide."
};
---

<Layout
  title="Services | Precision Estimating and Supplements"
  description="Xactimate estimate writing, supplement writing, carrier negotiations, and consulting for roofing contractors, GCs, and restoration companies. Nationwide remote service."
  canonical="https://supplementestimator.com/services"
  schema={schema}
>
  <section class="px-5 md:px-8 pt-32 pb-20 bg-secondary relative overflow-hidden">
    <div class="max-w-page mx-auto text-center relative z-10">
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-white mb-4 leading-tight">
        Everything You Need to Get Paid Right
      </h1>
      <p class="text-slate-300 text-lg md:text-xl max-w-2xl mx-auto">
        From writing the initial estimate to negotiating the final check — we handle the entire claims documentation process for roofing contractors, GCs, and restoration companies nationwide.
      </p>
    </div>
  </section>

  <section class="px-5 md:px-8 py-20 bg-primary">
    <div class="max-w-page mx-auto grid grid-cols-1 md:grid-cols-2 gap-8">

      <a href="/services/xactimate-estimate-writing" class="bg-surface border border-accent/15 hover:border-accent/40 rounded-2xl p-8 transition-colors group">
        <div class="w-12 h-12 bg-primary border border-accent/20 rounded-xl flex items-center justify-center mb-5">
          <i class="ti ti-file-description" style="font-size: 1.4rem; color: #14B8A6;"></i>
        </div>
        <h2 class="font-heading text-2xl font-bold text-white mb-3 group-hover:text-accent transition-colors">Xactimate Estimate Writing</h2>
        <p class="text-slate-400 leading-relaxed mb-4">Carrier-ready Xactimate estimates written by a certified professional and former licensed adjuster. Accurate scope, correct pricing, fast turnaround.</p>
        <span class="text-accent text-sm font-semibold">Learn more →</span>
      </a>

      <a href="/services/supplement-writing" class="bg-surface border border-accent/15 hover:border-accent/40 rounded-2xl p-8 transition-colors group">
        <div class="w-12 h-12 bg-primary border border-accent/20 rounded-xl flex items-center justify-center mb-5">
          <i class="ti ti-file-plus" style="font-size: 1.4rem; color: #14B8A6;"></i>
        </div>
        <h2 class="font-heading text-2xl font-bold text-white mb-3 group-hover:text-accent transition-colors">Supplement Writing</h2>
        <p class="text-slate-400 leading-relaxed mb-4">We audit carrier estimates, identify every missed or underpaid line item, and write complete supplements that recover money you're already owed.</p>
        <span class="text-accent text-sm font-semibold">Learn more →</span>
      </a>

      <a href="/services/carrier-negotiations" class="bg-surface border border-accent/15 hover:border-accent/40 rounded-2xl p-8 transition-colors group">
        <div class="w-12 h-12 bg-primary border border-accent/20 rounded-xl flex items-center justify-center mb-5">
          <i class="ti ti-gavel" style="font-size: 1.4rem; color: #14B8A6;"></i>
        </div>
        <h2 class="font-heading text-2xl font-bold text-white mb-3 group-hover:text-accent transition-colors">Carrier Negotiations</h2>
        <p class="text-slate-400 leading-relaxed mb-4">We negotiate directly with insurance carriers on your behalf — backed by a former adjuster who knows exactly how to document and argue a claim.</p>
        <span class="text-accent text-sm font-semibold">Learn more →</span>
      </a>

      <a href="/services/consulting-training" class="bg-surface border border-accent/15 hover:border-accent/40 rounded-2xl p-8 transition-colors group">
        <div class="w-12 h-12 bg-primary border border-accent/20 rounded-xl flex items-center justify-center mb-5">
          <i class="ti ti-school" style="font-size: 1.4rem; color: #14B8A6;"></i>
        </div>
        <h2 class="font-heading text-2xl font-bold text-white mb-3 group-hover:text-accent transition-colors">Consulting & Training</h2>
        <p class="text-slate-400 leading-relaxed mb-4">Improve your in-house claims process with Xactimate training and expert consulting from someone who has been on both sides of the table.</p>
        <span class="text-accent text-sm font-semibold">Learn more →</span>
      </a>

    </div>
  </section>

  <CTA />
</Layout>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css" />
