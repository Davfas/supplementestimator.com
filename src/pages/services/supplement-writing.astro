---
import ServicePage from '../../components/ServicePage.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Insurance Supplement Writing",
  "provider": {
    "@type": "ProfessionalService",
    "name": "Precision Estimating and Supplements",
    "url": "https://supplementestimator.com"
  },
  "description": "Expert insurance supplement writing for roofing, general contractors, and restoration companies. We identify missed line items and recover money carriers owe you.",
  "url": "https://supplementestimator.com/services/supplement-writing",
  "areaServed": { "@type": "Country", "name": "United States" },
  "serviceType": "Insurance Supplement Writing"
};

const benefits = [
  { icon: "ti-search", title: "We Find What Carriers Miss", body: "Carriers routinely underpay initial estimates. We audit every line item and identify every missed or underpaid scope item to build a complete supplement." },
  { icon: "ti-certificate", title: "7,000+ Claims Experience", body: "With thousands of supplements written, we know which items carriers fight and exactly how to document them to win approval." },
  { icon: "ti-shield-check", title: "Written by a Former Adjuster", body: "Our team has worked on the carrier side before switching to advocate for contractors. That insider knowledge means stronger supplements." },
  { icon: "ti-trending-up", title: "Average Recovery Increase", body: "Contractors who use our supplement service routinely recover thousands more per claim — money the carrier already owed them." },
  { icon: "ti-clock", title: "Fast Documentation", body: "We deliver complete, ready-to-submit supplement packages quickly so you're not waiting on paperwork to close jobs." },
  { icon: "ti-eye-off", title: "White Label Available", body: "We work under your brand. Your clients see only you — we handle everything behind the scenes." }
];

const faqs = [
  { q: "What is a supplement in insurance claims?", a: "A supplement is a request to add or increase line items on an existing insurance estimate. Carriers often miss items, underprice materials, or leave off required code upgrades. A supplement recovers that money for the contractor and policyholder." },
  { q: "How much more can I expect to recover?", a: "It varies by claim, but contractors typically see significant increases on supplemented estimates. We focus on documented, defensible line items — not inflated numbers that will get rejected." },
  { q: "What information do I need to provide?", a: "We need the original carrier estimate, your inspection photos, any material invoices or receipts, and notes on anything the adjuster missed during their inspection." },
  { q: "Will the carrier push back on supplements?", a: "Some do. That's why our supplements are written with full documentation, code citations, and carrier-specific language that makes it hard for them to deny. We also offer carrier negotiation services if needed." },
  { q: "How long does supplement writing take?", a: "Most supplements are completed within 24–48 hours of receiving all documentation. Complex commercial claims may take slightly longer." }
];
---

<ServicePage
  title="Insurance Supplement Writing for Contractors | Precision Estimating"
  description="Expert insurance supplement writing that recovers money carriers owe you. Written by a former licensed adjuster with 7,000+ claims experience. Roofing, GC, and restoration. Nationwide."
  canonical="https://supplementestimator.com/services/supplement-writing"
  headline="Supplement Writing That Recovers What Carriers Owe You"
  subheadline="Carriers underpay every day. We find the missed line items, document them properly, and get you the money you're owed."
  icon="ti-file-plus"
  image="/firefly-dual-monitor.png"
  benefits={benefits}
  faqs={faqs}
  schema={schema}
/>
